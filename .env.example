# Copy this file to .env when you want local-only Neovim environment overrides.
# The config-root .env is loaded automatically at startup.
# Project .env files are loaded manually with :EnvLoad.

# Gemini translation helpers.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Optional Neovim log destination override.
NVIM_LOG_FILE=

# Optional Python/LSP environment overrides.
VIRTUAL_ENV=
PYTHONPATH=

# Add any local-only variables below.
